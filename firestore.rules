rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 'users' collection actually stores release/artist information in this project
    match /users/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /radioshow/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /accurate-sessions/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

